# ============================================================
# inventory-frontend — Variables de entorno BASE
#
# Este archivo SE VERSIONA en git. Solo contiene valores
# seguros por defecto (localhost). Nunca pongas aquí URLs
# reales de producción, tokens ni secretos.
#
# Prioridad de carga (mayor a menor):
#   .env.local              ← overrides personales (git ignored)
#   .env.[mode].local       ← override por modo (git ignored)
#   .env.[mode]             ← .env.development / .env.production
#   .env                    ← este archivo (base)
#
# Para desarrollo local: crea/edita .env.local
# Para producción:       usa variables de CI/CD o build-arg Docker
# ============================================================

# URL base del backend Spring Boot (sin slash al final)
VITE_API_BASE_URL=http://localhost:8080

