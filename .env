# ============================================================
# inventory-frontend — Variables de entorno base
# Para desarrollo local crea .env.local y sobreescribe los valores.
# NUNCA comitas .env.local al repositorio.
# ============================================================

# URL base del backend (sin slash al final)
VITE_API_BASE_URL=http://localhost:8080

# Hosts permitidos en el servidor de desarrollo Vite
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

