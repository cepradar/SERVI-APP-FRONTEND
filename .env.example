# ============================================================
# inventory-frontend — Variables de entorno (EJEMPLO)
# Copia este archivo a .env.local para desarrollo local.
# NUNCA comitas .env.local al repositorio.
# ============================================================

# URL base del backend Spring Boot (sin slash al final)
# En producción apunta a tu dominio o IP pública del backend
VITE_API_BASE_URL=http://localhost:8080

# Hosts adicionales permitidos en el servidor de desarrollo Vite
# En desarrollo local normalmente no se necesita cambiar
VITE_ALLOWED_HOSTS=localhost,127.0.0.1
